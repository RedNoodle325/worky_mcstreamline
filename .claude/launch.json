{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run"],
      "port": 3000,
      "cwd": "backend"
    },
    {
      "name": "backend-react",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run"],
      "port": 3000,
      "cwd": "backend",
      "env": {
        "FRONTEND_DIR": "../frontend-react-dist"
      }
    },
    {
      "name": "react-dev",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend-react"
    }
  ]
}
